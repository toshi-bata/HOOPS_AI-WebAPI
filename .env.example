# HOOPS AI runtime settings

# HOOPS AI license key — read only from this file (required)
HOOPS_AI_LICENSE=your_license_key_here

# Absolute path to the HOOPS AI SDK install directory  Emust contain notebooks/ and packages/ (required)
HOOPS_AI_SDK_DIR=C:\path\to\hoops_ai

# MFR flow name (required for all /MFR/* endpoints).
# Must match the ETL flow output directory under <HOOPS_AI_SDK_DIR>/notebooks/out/flows/.
#
# PREREQUISITE: Before using any MFR feature, run the tutorial notebook
#   notebooks/3b_workflow_for_MFR_cadsynth.ipynb
# This generates the following files and folders required at runtime:
#   <HOOPS_AI_SDK_DIR>/notebooks/out/flows/ETL_CADSYNTH_training_b2/
#     ├── ETL_CADSYNTH_training_b2.dataset    (CAD graph dataset)
#     ├── ETL_CADSYNTH_training_b2.infoset    (file metadata incl. stream_cache paths)
#     ├── ETL_CADSYNTH_training_b2.attribset  (attribute data)
#     └── stream_cache/                       (pre-rendered PNG thumbnails)
#HOOPS_AI_MFR_FLOW_NAME=ETL_CADSYNTH_training_b2

# MFR trained model checkpoint filename under packages/trained_ml_models/ (required)
HOOPS_AI_MFR_MODEL_NAME=ts3d_162k_mfr.ckpt

# Embeddings checkpoint for the 'legacy' preset (1M model), under packages/trained_ml_models/ (optional).
#HOOPS_AI_EMBEDDINGS_MODEL_NAME=ts3d_1M_hoops_embeddings.ckpt

# FAISS index for the 'legacy' preset, under notebooks/ (optional).
# Generated by 5b_cad_search_using_HOOPS_embeddings.ipynb (up to "Saving an Index").
#HOOPS_AI_FAISS_INDEX_PATH=fabwave_embeddings_store.faiss

# Embeddings checkpoint for the 'signal' preset (SIGNAL model, default), under packages/trained_ml_models/.
HOOPS_AI_EMBEDDINGS_MODEL_NAME_SIGNAL=ts3d_2M_hoops_embeddings_SIGNAL-preview.ckpt

# FAISS index filename for the 'signal' preset (default), under packages/vectorstores/tmcad/.
# Download the TMCAD_SIGNAL.faiss bundle from Tech Soft 3D File Transfer  Eno notebook run needed.
HOOPS_AI_FAISS_INDEX_PATH_SIGNAL=TMCAD_SIGNAL.faiss

# Directory containing pre-generated CAD thumbnail images for similarity search results.
# Defaults to <HOOPS_AI_SDK_DIR>/notebooks/out/images — the path used when embed_shape_batch is run
# with specifications={"generate_images": True, "images_out_dir": ...} in notebook 5b.
# Override only if you saved the images to a different location.
#HOOPS_AI_EMBEDDINGS_IMAGES_DIR=C:\path\to\hoops_ai\notebooks\out\images

# ---------------------------------------------------------------------------
# Part Classification settings (required for /part-classification/* endpoints)
# ---------------------------------------------------------------------------

# Trained GraphClassification checkpoint filename under packages/trained_ml_models/
HOOPS_AI_PART_CLASS_MODEL_NAME=ts3d_graphclassification_5k_10epochs.ckpt

# Flow name for the part classification dataset (required for /dataset/* endpoints).
# Prefers <HOOPS_AI_SDK_DIR>/notebooks/out/flows/<name> (notebook output); falls back to packages/flows/<name>.
HOOPS_AI_PART_CLASS_FLOW_NAME=ETL_Fabwave_training_b2

# Label array key for dataset queries. Use "task_A" for custom ETL.
#HOOPS_AI_PART_CLASS_LABEL_KEY=part_label

# ---------------------------------------------------------------------------
# Demo-only endpoints switch
# ---------------------------------------------------------------------------

# Enables endpoints that mutate server state or run long/heavy jobs:
#   - GET/PUT  /similarity/default-model/setting        (embedding-model switch)
#   - POST     /similarity/index/create                 (named index create)
#   - GET      /similarity/index/list                   (named index list)
#   - POST     /similarity/index/add                     (named index add)
#   - DELETE   /similarity/index/{name}/parts            (named index remove parts)
#   - DELETE   /similarity/index/{name}                  (named index delete)
#   - POST     /similarity/map                           (Shape Space Map generate)
#   - GET      /similarity/map/job/{job_id}               (Shape Space Map poll)
#   - POST     /similarity/map/{map_id}/query             (Shape Space Map query)
#   - POST     /similarity/map/{map_id}/add-to-index      (Shape Space Map -> index)
#   - GET      /MFR/dataset/table-of-contents, /MFR/labels/description,
#              /MFR/files/search, /MFR/files/{file_id}/thumbnail
#   - GET      /part-classification/dataset/table-of-contents,
#              /part-classification/dataset/label-distribution
#   - POST     /context/predict
#
# These are the WebAPI counterparts of the MCP tools that live in the private
# HOOPS_AI-MCPServer-demo companion repo. When this flag is "false" or unset
# (the default), the routes above return 404 — indistinguishable from a route
# that does not exist on this deployment. Set to "true" only on servers used
# for internal demos.
#HOOPS_AI_ENABLE_DEMO_FEATURES=false