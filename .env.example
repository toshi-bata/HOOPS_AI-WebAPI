# HOOPS AI runtime settings

# HOOPS AI license key — read only from this file (required)
HOOPS_AI_LICENSE=your_license_key_here

# Absolute path to the HOOPS AI notebooks directory (required)
HOOPS_AI_NOTEBOOK_DIR=C:\path\to\hoops_ai\notebooks

# MFR flow name (required for all /MFR/* endpoints).
# Must match the ETL flow output directory under <HOOPS_AI_NOTEBOOK_DIR>/out/flows/.
#
# PREREQUISITE: Before using any MFR feature, run the tutorial notebook
#   notebooks/3b_workflow_for_MFR_cadsynth.ipynb
# This generates the following files and folders required at runtime:
#   <HOOPS_AI_NOTEBOOK_DIR>/out/flows/ETL_CADSYNTH_training_b2/
#     ├── ETL_CADSYNTH_training_b2.dataset    (CAD graph dataset)
#     ├── ETL_CADSYNTH_training_b2.infoset    (file metadata incl. stream_cache paths)
#     ├── ETL_CADSYNTH_training_b2.attribset  (attribute data)
#     └── stream_cache/                       (pre-rendered PNG thumbnails)
HOOPS_AI_MFR_FLOW_NAME=ETL_CADSYNTH_training_b2

# MFR trained model checkpoint filename under notebooks/../packages/trained_ml_models/ (required)
HOOPS_AI_MFR_MODEL_NAME=ts3d_162k_mfr.ckpt

# Embeddings trained model checkpoint filename under notebooks/../packages/trained_ml_models/ (required)
HOOPS_AI_EMBEDDINGS_MODEL_NAME=ts3d_1M_hoops_embeddings.ckpt

# FAISS index file for shape similarity search, located directly under HOOPS_AI_NOTEBOOK_DIR.
# Generated by running 5b_cad_search_using_HOOPS_embeddings.ipynb up to "Saving an Index". (required for similarity search)
HOOPS_AI_FAISS_INDEX_PATH=fabwave_embeddings_store.faiss

# Directory containing pre-generated CAD thumbnail images for similarity search results.
# Defaults to <HOOPS_AI_NOTEBOOK_DIR>/out/images — the path used when embed_shape_batch is run
# with specifications={"generate_images": True, "images_out_dir": ...} in notebook 5b.
# Override only if you saved the images to a different location.
#HOOPS_AI_EMBEDDINGS_IMAGES_DIR=C:\path\to\hoops_ai\notebooks\out\images

# ---------------------------------------------------------------------------
# Part Classification settings (required for /part-classification/* endpoints)
# ---------------------------------------------------------------------------

# Trained GraphClassification checkpoint filename under notebooks/../packages/trained_ml_models/
HOOPS_AI_PART_CLASS_MODEL_NAME=ts3d_graphclassification_5k_10epochs.ckpt

# Flow name for the part classification dataset (required for /dataset/* endpoints).
# Prefers <HOOPS_AI_NOTEBOOK_DIR>/out/flows/<name> (notebook output); falls back to ../packages/flows/<name>.
HOOPS_AI_PART_CLASS_FLOW_NAME=ETL_Fabwave_training_b2

# Label array key for dataset queries. Use "task_A" for custom ETL.
#HOOPS_AI_PART_CLASS_LABEL_KEY=part_label